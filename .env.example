# PostgreSQL durable queue and application data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoice_resolution

# Local file storage. Replace with S3/Supabase storage behind the same interface later.
STORAGE_DIR=./storage

# Queue/retry controls
JOB_LEASE_SECONDS=300
JOB_MAX_ATTEMPTS=3
WORKER_POLL_SECONDS=1

# MEDHA (self-hosted Gemma 4 26B / vLLM endpoint)
# Never commit a real internal endpoint or key.
MEDHA_API_URL=
MEDHA_API_KEY=
MEDHA_MODEL=Medha
MEDHA_TIMEOUT_SECONDS=120
MEDHA_MAX_RETRIES=1
MEDHA_JSON_MODE=true

# Extraction switches
ENABLE_MEDHA=true
ENABLE_PADDLE_OCR=false
NATIVE_TEXT_MIN_CHARS=80
MAX_PDF_PAGES=8
MAX_UPLOAD_MB=15
# Optional byte-level override for infrastructure with strict request limits.
MAX_UPLOAD_BYTES=
MAX_RENDER_PIXELS=40000000

# Authentication. Development identity is intentionally only valid with ENVIRONMENT=development.
ENVIRONMENT=development
AUTH_MODE=development
DEMO_ACTOR_ID=local-demo-admin
DEMO_ACTOR_NAME=Local Demo Admin (development only)
DEMO_ACTOR_ROLE=admin
# Production: set ENVIRONMENT=production, AUTH_MODE=jwt, and a strong JWT_SECRET.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_AUDIENCE=

# Business policy version becomes part of a job's idempotency key.
POLICY_VERSION=2026-07-v1
